---
// Shared <head> + closing site scripts for all public pages.
// Per-page values come in as props; og:image and favicons are site-wide.
const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogUrl,
  twitterTitle,
  twitterDescription,
  fontsHref,
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="icon" href="/favicon-32.png" sizes="32x32">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<meta property="og:type" content="website">
<meta property="og:site_name" content="No Half Measures">
<meta property="og:title" content={ogTitle}>
<meta property="og:description" content={ogDescription}>
<meta property="og:url" content={ogUrl}>
<meta property="og:image" content="https://nhmlife.com/og.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={twitterTitle}>
<meta name="twitter:description" content={twitterDescription}>
<meta name="twitter:image" content="https://nhmlife.com/og.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href={fontsHref} rel="stylesheet">
<slot name="head" />
</head>
<body>
<slot />
<script is:inline src="/assets/analytics.js" defer></script>
<script is:inline src="/assets/content.js" defer></script>
<script is:inline src="/assets/edit.js" defer></script>
<script is:inline src="/assets/newsletter.js" defer></script>
</body>
</html>
